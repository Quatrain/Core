{
   "extends": "@tsconfig/recommended/tsconfig.json",
   "compileOnSave": true,
   "compilerOptions": {
      "rootDir": "src",
      "outDir": "dist",
      "declaration": true,
      "target": "es2020",
      "module": "esnext",
      "moduleResolution": "node",
      "resolveJsonModule": true,
      "strict": true
   },
   "include": ["src"],
   "exclude": ["node_modules"]
}

{
   "name": "@quatrain/storage-s3",
   "version": "1.1.14",
   "description": "Storage adapter for S3 compatible services",
   "main": "lib/index.js",
   "types": "lib/index.d.ts",
   "bun": "src/index.ts",
   "files": [
      "LICENSE.md",
      "src/",
      "lib/",
      "README.md"
   ],
   "author": "Quatrain Développement SAS <developers@quatrain.com>",
   "license": "AGPL-3.0-only",
   "devDependencies": {
      "@tsconfig/recommended": "^1.0.1",
      "@types/jest": "^27.0.3",
      "@types/node": "^22.10.1",
      "jest": "^30.2.0",
      "jest-node-exports-resolver": "^1.1.6",
      "trace-unhandled": "^2.0.1",
      "ts-jest": "^27.1.2",
      "ts-node": "^10.4.0",
      "typescript": "^5.1.5"
   },
   "dependencies": {
      "@aws-sdk/client-s3": "^3.337.0",
      "@aws-sdk/s3-request-presigner": "^3.342.0",
      "@quatrain/storage": "^1.1.23",
      "fs-extra": "^11.2.0"
   },
   "scripts": {
      "test-ci": "jest --runInBand",
      "build": "tsc",
      "wbuild": "tsc --watch",
      "bump-to": "yarn version",
      "hash": "node ../../bin/hashFolder.js",
      "hash:persist": "yarn hash  > .hash_latest.txt",
      "hash:compare": "yarn hash > .hash_newest.txt && cmp -s .hash_latest.txt .hash_newest.txt",
      "release": "yarn hash:compare || yarn release:process",
      "release:process": "yarn version patch && yarn build && cp ../../LICENSE.md . && yarn pack --out package.tgz && npm publish package.tgz --access public && rm package.tgz && yarn hash:persist"
   }
}
